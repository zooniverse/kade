<div class="row">
  <div class="col-md-12">
    <div class="page-actions">
      <%= link_to 'Back to training jobs', admin_training_jobs_path, class: 'btn btn-default' %>
    </div>
    <h2>Training Job <%= @training_job.id %></h2>
  </div>
</div>

<div class="row">
  <div class="col-md-12">
    <table class="table table-striped table-sm">
      <tbody>
        <tr><th>Workflow ID</th><td><%= @training_job.workflow_id %></td></tr>
        <tr><th>State</th><td><%= @training_job.state %></td></tr>
        <tr><th>Manifest URL</th><td><%= @training_job.manifest_url %></td></tr>
        <tr><th>Manifest Path</th><td><%= @training_job.manifest_path %></td></tr>
        <tr><th>Service Job URL</th><td><%= @training_job.service_job_url.presence || '-' %></td></tr>
        <tr><th>Results URL</th><td><%= @training_job.results_url.presence || '-' %></td></tr>
        <tr><th>Message</th><td><%= @training_job.message.presence || '-' %></td></tr>
        <tr><th>Updated</th><td><%= @training_job.updated_at %></td></tr>
      </tbody>
    </table>
  </div>
</div>
