<div class="row">
  <div class="col-md-12">
    <h2>Edit Context <%= @context.id %></h2>
    <p class="text-muted">This uses the same validation path as the JSON API for integer fields, metadata shape, batch runtime config, and extractor pair resolution.</p>
    <%= render 'form',
      form_model: @context,
      form_url: admin_context_path(@context),
      form_method: :patch,
      submit_label: 'Save context' %>
  </div>
</div>
