<div class="row">
  <div class="col-md-12">
    <h2>Add Context</h2>
    <p class="text-muted">Create a new workflow context and optionally seed its metadata batch configuration.</p>
    <%= render 'form',
      form_model: @context,
      form_url: admin_contexts_path,
      form_method: :post,
      submit_label: 'Create context' %>
  </div>
</div>
