<% definition = form_model || LabelExtractorDefinition.new(enabled: true) %>
<%
  config_json =
    local_assigns[:config_json_value].presence ||
    @config_json_value.presence ||
    pretty_json(definition.config)
%>

<%= form_with model: definition, url: form_url, method: form_method do |form| %>
  <%= hidden_field_tag :return_to, local_assigns[:return_to].presence || @return_to %>
  <div class="form-group">
      <%= form.label :module_name %>
      <%= form.text_field :module_name, class: 'form-control' %>
  </div>
  <div class="form-group">
      <%= form.label :extractor_name %>
      <%= form.text_field :extractor_name, class: 'form-control' %>
  </div>
  <div class="form-group">
    <label>
      <%= form.check_box :enabled, checked: definition.enabled? %>
      Enabled
    </label>
  </div>

  <div class="form-group">
    <%= form.label :config_json, 'Config JSON' %>
    <%= form.text_area :config_json,
      value: config_json,
      class: 'form-control json-editor',
      data: {
        json_editor: true,
        json_field_name: 'Config JSON'
      } %>
    <p class="help-block">Structured JSON only. Arbitrary executable logic is not supported. Valid JSON is formatted when the field loses focus or the form is submitted.</p>
    <p class="help-block json-editor-status" aria-live="polite"></p>
  </div>

  <%= form.submit submit_label, class: 'btn btn-primary' %>
<% end %>
