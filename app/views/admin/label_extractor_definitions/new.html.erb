<div class="row">
  <div class="col-md-12">
    <h2>Add Label Extractor Definition</h2>
    <p class="text-muted">Definitions are global and unique by module and extractor pair, not tied to a specific context page.</p>
    <%= render 'form',
      form_model: @definition,
      form_url: admin_label_extractor_definitions_path,
      form_method: :post,
      submit_label: 'Create definition' %>
  </div>
</div>
