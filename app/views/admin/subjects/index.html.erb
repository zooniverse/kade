<div class="row">
  <div class="col-md-12">
    <h2>Subjects</h2>
    <table class="table table-striped table-sm">
      <thead>
        <tr>
          <th>ID</th>
          <th>Zooniverse Subject ID</th>
          <th>Context</th>
          <th>Reductions</th>
          <th>Predictions</th>
          <th>Updated</th>
        </tr>
      </thead>
      <tbody>
        <% @subjects.each do |subject| %>
          <tr>
            <td><%= link_to subject.id, admin_subject_path(subject) %></td>
            <td><%= subject.zooniverse_subject_id %></td>
            <td><%= link_to subject.context_id, admin_context_path(subject.context_id) %></td>
            <td><%= subject.reductions.size %></td>
            <td><%= subject.predictions.size %></td>
            <td><%= subject.updated_at %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= render 'admin/shared/pagination', pagination: @pagination %>
  </div>
</div>
