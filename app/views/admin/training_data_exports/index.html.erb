<div class="row">
  <div class="col-md-12">
    <h2>Training Data Exports</h2>
    <table class="table table-striped table-sm">
      <thead>
        <tr>
          <th>ID</th>
          <th>Workflow ID</th>
          <th>State</th>
          <th>Storage Path</th>
          <th>File</th>
          <th>Updated</th>
        </tr>
      </thead>
      <tbody>
        <% @training_data_exports.each do |training_data_export| %>
          <tr>
            <td><%= link_to training_data_export.id, admin_training_data_export_path(training_data_export) %></td>
            <td><%= training_data_export.workflow_id %></td>
            <td><%= training_data_export.state %></td>
            <td><%= training_data_export.storage_path %></td>
            <td><%= training_data_export.file.attached? ? 'Attached' : 'Not attached' %></td>
            <td><%= training_data_export.updated_at %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= render 'admin/shared/pagination', pagination: @pagination %>
  </div>
</div>
